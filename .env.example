# =============================================================================
# Mediabox MCP — Environment Variables
# Copy this file to .env and fill in your values
# Or use: npx create-mediabox (auto-generates everything)
# =============================================================================

# Deployment mode: local or vps
DEPLOYMENT_MODE=local
# BASE_DOMAIN=yourdomain.com  # only for VPS mode

# Timezone (used by all services)
TZ=UTC

# ── Jellyfin ─────────────────────────────────────────────────────────────────
JELLYFIN_API_KEY=

# ── Download stack ───────────────────────────────────────────────────────────
SONARR_API_KEY=
RADARR_API_KEY=
PROWLARR_API_KEY=
QBIT_PASSWORD=
PYLOAD_USER=pyload
PYLOAD_PASSWORD=pyload

# PyLoad is the one service whose host port differs from the container port
# (Docker maps 8001:8000). Dashboard & Service Dock use this to open the web UI.
PYLOAD_HOST_PORT=8001

# Optional: subtitle management (Bazarr is disabled by default)
BAZARR_ENABLED=false
# BAZARR_URL=http://bazarr:6767

# Optional override — Cloudflare bypass proxy (defaults to http://flaresolverr:8191)
# FLARESOLVERR_URL=http://flaresolverr:8191

# ── MCP Server ───────────────────────────────────────────────────────────────
MCP_PUBLIC_URL=https://your-domain.com
# Shared secret for the Telegram bot and the Dashboard/Chat REST API.
# Also read by the UI as VITE_INTERNAL_API_KEY (see packages/ui/.env.local.example).
INTERNAL_API_KEY=
# Image tag for ghcr.io images (default: latest published release)
IMAGE_TAG=2.2.0-beta.3

# ── Chat / LLM ───────────────────────────────────────────────────────────────
# Set at least one key to enable chat (Telegram bot + /api/chat endpoint).
# LLM_PROVIDER: "openrouter" or "google" (auto-detected if omitted).
LLM_PROVIDER=openrouter
LLM_MODEL=openai/gpt-4o
OPENROUTER_API_KEY=
GOOGLE_AI_API_KEY=

# ── Telegram bot (optional) ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
ALLOWED_TELEGRAM_USERS=
