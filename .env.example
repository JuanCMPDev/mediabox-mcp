# =============================================================================
# Mediabox MCP — Environment Variables
# Copy this file to .env and fill in your values
# Or use: npx create-mediabox (auto-generates everything)
# =============================================================================

# Deployment mode: local or vps
DEPLOYMENT_MODE=local
# BASE_DOMAIN=yourdomain.com  # only for VPS mode

# Timezone (used by all services)
TZ=UTC

# Jellyfin
JELLYFIN_API_KEY=

# Download stack
SONARR_API_KEY=
RADARR_API_KEY=
QBIT_PASSWORD=
PYLOAD_USER=pyload
PYLOAD_PASSWORD=pyload

# MCP Server
MCP_PUBLIC_URL=https://your-domain.com
MCP_AUTH_SECRET=
INTERNAL_API_KEY=

# Telegram bot (optional)
TELEGRAM_BOT_TOKEN=
LLM_PROVIDER=openrouter
LLM_MODEL=openai/gpt-4o
OPENROUTER_API_KEY=
GOOGLE_AI_API_KEY=
ALLOWED_TELEGRAM_USERS=
