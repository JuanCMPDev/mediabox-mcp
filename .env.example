# =============================================================================
# Mediabox MCP — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# Timezone (used by all services)
TZ=UTC

# Jellyfin
JELLYFIN_API_KEY=

# Download stack
SONARR_API_KEY=
RADARR_API_KEY=
QBIT_PASSWORD=

# MCP Server
MCP_PUBLIC_URL=https://your-domain.com
MCP_AUTH_SECRET=
INTERNAL_API_KEY=

# Telegram bot (optional)
TELEGRAM_BOT_TOKEN=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o
GOOGLE_AI_API_KEY=
ALLOWED_TELEGRAM_USERS=
