{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@mediabox/core": ["packages/core/src/index.ts"],
      "@mediabox/core/*": ["packages/core/src/*"]
    }
  }
}
