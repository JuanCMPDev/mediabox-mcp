# ── @mediabox/ui — local dev config ─────────────────────────────────────────
# Copy this to .env.local and fill in the values.

# MCP server base URL (same machine, different port)
VITE_API_URL=http://localhost:3000

# Must match INTERNAL_API_KEY in packages/mcp-server/.env
VITE_INTERNAL_API_KEY=changeme-generate-a-secure-random-string
