# Tauri build artifacts
src-tauri/target/
src-tauri/gen/

# Sidecar binaries (regenerated per platform via `bun build --compile`)
src-tauri/binaries/*

# Auto-generated icons (regenerate with `npm run icons`)
# Keep these committed so CI does not need a square source image.
# src-tauri/icons/

# Cargo.lock is committed — Tauri produces a distributable binary,
# so we want reproducible dep versions across machines and CI.

# Build outputs
dist/

# Generated by scripts/prep-icon.mjs
.icon-square.png

# Generated by scripts/smoke-execa.mjs (bun --compile output)
.smoke-execa.exe
.smoke-execa
