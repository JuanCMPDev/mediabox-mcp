{
  "name": "create-mediabox",
  "version": "2.1.0-beta.0",
  "description": "CLI wizard to auto-configure the Mediabox MCP self-hosted media server stack",
  "type": "module",
  "bin": {
    "create-mediabox": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/JuanCMPDev/mediabox-mcp.git",
    "directory": "packages/mediabox-cli"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "chalk": "^5.4.0",
    "ora": "^8.1.0"
  },
  "devDependencies": {
    "@mediabox/core": "*",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "mediabox",
    "jellyfin",
    "sonarr",
    "radarr",
    "mcp",
    "self-hosted",
    "media-server",
    "docker"
  ],
  "license": "MIT"
}
