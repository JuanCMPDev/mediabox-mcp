{
  "name": "mediabox-monorepo",
  "version": "2.1.0-beta.0",
  "private": true,
  "description": "Mediabox MCP monorepo — AI-powered self-hosted media stack",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build":    "npm run build --workspaces --if-present",
    "test":     "npm run test  --workspaces --if-present",
    "typecheck":"npm run build --workspaces --if-present",
    "dev":      "npm-run-all --parallel dev:mcp dev:ui",
    "dev:mcp":  "npm run dev --workspace packages/mcp-server",
    "dev:ui":   "npm run dev --workspace packages/ui"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
