{
  "name": "mediabox-monorepo",
  "version": "2.1.0-beta.0",
  "private": true,
  "description": "Mediabox MCP monorepo — AI-powered self-hosted media stack",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test  --workspaces --if-present",
    "typecheck": "npm run build --workspaces --if-present",
    "dev": "npm-run-all --parallel dev:mcp dev:ui",
    "dev:mcp": "npm run dev --workspace packages/mcp-server",
    "dev:ui": "npm run dev --workspace packages/ui",
    "dev:desktop": "npm run dev    --workspace packages/desktop",
    "build:desktop": "npm-run-all --serial build:ui sidecar:build bundle:desktop",
    "build:ui": "npm run build  --workspace packages/ui",
    "sidecar:build": "node packages/desktop/scripts/build-sidecar.mjs",
    "bundle:desktop": "npm run bundle --workspace packages/desktop",
    "icons:desktop": "npm run icons  --workspace packages/desktop"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  },
  "volta": {
    "node": "22.19.0"
  }
}
